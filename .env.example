# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ─── Databases ───────────────────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=ragdb
DATABASE_URL=postgresql://rag:changeme_postgres@postgres:5432/ragdb

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
REDIS_URL=redis://:changeme_redis@redis:6379

# ─── Weaviate ────────────────────────────────────────────────
WEAVIATE_API_KEY=changeme_weaviate
WEAVIATE_URL=http://weaviate:8080

# ─── OpenSearch ──────────────────────────────────────────────
OPENSEARCH_PASSWORD=Changeme_opensearch1!
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin

# ─── Embedder microservice ───────────────────────────────────
EMBEDDER_URL=http://embedder:8001
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_MODEL_VERSION=bge-m3-v1

# ─── Reranker microservice ───────────────────────────────────
RERANKER_URL=http://reranker:8002
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ─── LLM (Ollama) ────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=llama3.1:8b

# ─── Observability ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=adaptive-rag-engine

# ─── Grafana ─────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme_grafana

# ─── App settings ────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
RATE_LIMIT_PER_MINUTE=100
SEMANTIC_CACHE_THRESHOLD=0.95
RAGAS_FAITHFULNESS_TARGET=0.80
