# Lighter Models for Low-RAM Environments
# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ─── Databases ───────────────────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=ragdb
DATABASE_URL=postgresql://rag:changeme_postgres@postgres:5432/ragdb

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
REDIS_URL=redis://:changeme_redis@redis:6379

# ─── Weaviate ────────────────────────────────────────────────
WEAVIATE_API_KEY=changeme_weaviate
WEAVIATE_URL=http://weaviate:8080

# ─── OpenSearch ──────────────────────────────────────────────
OPENSEARCH_PASSWORD=Changeme_opensearch1!
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin

# ─── Embedder microservice (LIGHT) ───────────────────────────
EMBEDDER_URL=http://embedder:8001
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL_VERSION=bge-small-v1.5

# ─── Reranker microservice (LIGHT) ───────────────────────────
RERANKER_URL=http://reranker:8002
RERANKER_MODEL=BAAI/bge-reranker-base

# ─── LLM (Ollama - LIGHT) ────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_FALLBACK_MODEL=phi3:mini

# ─── App settings ────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
RATE_LIMIT_PER_MINUTE=100
SEMANTIC_CACHE_THRESHOLD=0.95
RAGAS_FAITHFULNESS_TARGET=0.80
